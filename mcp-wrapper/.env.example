# ============================================
# GitHub MCP Server 설정 (로컬 개발용)
# ============================================
# Docker에서 실행 시: 프로젝트 루트의 .env 참고
# npm start로 로컬 실행 시: 아래 설정 필요
# ============================================

# GitHub API 토큰
GITHUB_TOKEN=ghp_your_personal_access_token_here

# 저장소 정보
GITHUB_OWNER=leejk0924
GITHUB_REPO=amazon2-backend
REPOSITORY=leejk0924/amazon2-backend

# MCP 서버 설정
MCP_PORT=3000
MCP_HOST=127.0.0.1

# 로깅 레벨
LOG_LEVEL=info

# 환경
NODE_ENV=development

# CONTRIBUTING.md 경로 (Docker 컨테이너 내부)
CONTRIBUTING_MD_PATH=/app/docs/CONTRIBUTING.md
